  <!-- EXPERIMENTAL OBJECTIVES -->
  <owl:NamedIndividual rdf:about="http://www.semanticweb.org/noamaadra/ontologies/2024/2/Horses#GaitClassif_01">
    <rdf:type rdf:resource="http://www.semanticweb.org/noamaadra/ontologies/2024/2/Horses#ExperimentalObjective"/>
    <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gait Classification</hasName>
    <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Classification of horse gaits using IMU data from withers and hindlimb canon</description>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.semanticweb.org/noamaadra/ontologies/2024/2/Horses#FatigueDetection">
    <rdf:type rdf:resource="http://www.semanticweb.org/noamaadra/ontologies/2024/2/Horses#ExperimentalObjective"/>
    <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fatigue Detection</hasName>
    <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Detection of physical fatigue in competition horses using sternum and forelimb canon sensors</description>
  </owl:NamedIndividual>

