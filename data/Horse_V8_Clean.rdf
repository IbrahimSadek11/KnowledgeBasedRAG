    <!-- ================================================================ -->
    <!--  V8 CLEAN — Generated from verified Neo4j export (429 nodes,      -->
    <!--  1194 relations after HASPARTICIPATEDTO removal).                 -->
    <!--  Cleanup pass by Ibrahim Sadek, June 2026:                        -->
    <!--    - hasParticipatedTo removed (redundant with dependsOn,         -->
    <!--      confirmed isolated to a single node, duplicated in source).  -->
    <!--    - eventDate / seasonStart / seasonEnd normalized to xsd:date.  -->
    <!--    - Training intensity normalized to French                     -->
    <!--      (High->Élevée, Moderate->Modérée, Low->Faible, Peak->Pic).   -->
    <!--    - Neo4j/Cypher relationship TYPES were renamed to              -->
    <!--      ALL_CAPS_WITH_UNDERSCORES (see questions file); RDF/XML      -->
    <!--      object-property tag casing below is UNCHANGED from the       -->
    <!--      original ontology by explicit decision (camelCase/PascalCase -->
    <!--      is the correct RDF/XML convention, not ALL_CAPS).            -->
    <!-- ================================================================ -->

